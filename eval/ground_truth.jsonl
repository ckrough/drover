# Ground Truth Dataset for Classification Evaluation
# Format: One JSON object per line (JSONL)
# Required fields: filename, domain, category, doctype
# Optional fields: vendor, date, subject, notes
#
# Conventions (must match prompts/classification.md):
#   - domain / category / doctype: canonical values from src/drover/taxonomy/household.py
#   - vendor: full organization name (e.g., "Northern Virginia Medical Center")
#   - subject: 2-4 lowercase words describing content (not document type)
#   - date: YYYYMMDD, or "00000000" if no date is available
#
# Usage (filenames below resolve under --documents-dir):
#   drover evaluate --ground-truth eval/ground_truth.jsonl --documents-dir eval/samples
{"filename": "medical_bill.pdf", "domain": "medical", "category": "expense", "doctype": "invoice", "vendor": "Northern Virginia Medical Center", "date": "20241101", "subject": "medical services", "notes": "Itemized medical services bill"}
{"filename": "receipt.pdf", "domain": "pets", "category": "expense", "doctype": "receipt", "vendor": "PetSmart", "date": "20241208", "subject": "pet supplies", "notes": "Retail receipt for pet supplies"}
{"filename": "user_manual.pdf", "domain": "household", "category": "documentation", "doctype": "manual", "vendor": "smarthub", "date": "20240901", "subject": "smarthub 3000", "notes": "Device manual for SmartHub 3000"}
